<Page x:Class="diplomnarabotki.MapPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Карта маршрута"
      Background="#F5F5F5"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="White" CornerRadius="5" 
                BorderBrush="#E0E0E0" BorderThickness="1" Margin="10" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnBack" Content="← Назад к планеру" 
                        Click="BtnBack_Click" Width="150" Height="35" Margin="5"
                        Background="#2196F3" Foreground="White" BorderThickness="0"
                        Cursor="Hand" FontWeight="Bold"/>

                <Separator Width="20"/>

                <TextBlock Text="Текущее путешествие:" VerticalAlignment="Center" 
                           Margin="5,0" FontSize="12" Foreground="#666"/>
                <ComboBox x:Name="CmbTravels" Width="200" Height="35" Margin="5"
                          SelectionChanged="CmbTravels_SelectionChanged"
                          FontSize="12" Background="White"/>

                <Separator Width="20"/>

                <Button x:Name="BtnSavePoints" Content="💾 Сохранить точки" 
                        Click="BtnSavePoints_Click" Width="130" Height="35" Margin="5"
                        Background="#4CAF50" Foreground="White" BorderThickness="0"
                        Cursor="Hand" FontWeight="Bold"/>

                <Button x:Name="BtnLoadPoints" Content="📂 Загрузить точки" 
                        Click="BtnLoadPoints_Click" Width="130" Height="35" Margin="5"
                        Background="#FF9800" Foreground="White" BorderThickness="0"
                        Cursor="Hand" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- WebBrowser для карты -->
        <WebBrowser x:Name="WebBrowserMap" Grid.Row="1" Margin="10"/>
    </Grid>
</Page>