<Window x:Class="diplomnarabotki.Views.CreateTravelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="✈️ Новое путешествие" 
        Height="450" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="350" MinWidth="450"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="35"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Border Background="White" CornerRadius="10" 
            BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок для перетаскивания -->
            <Border Grid.Row="0" Background="#4CAF50" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="✈️ Создание нового путешествия" 
                               FontSize="14" FontWeight="Bold" 
                               Foreground="White" VerticalAlignment="Center"
                               Margin="15,0,0,0"/>
                    <Button x:Name="BtnClose" Content="✖" 
                            Width="30" Height="30" 
                            HorizontalAlignment="Right" Margin="0,0,10,0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="14" Cursor="Hand"
                            Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <!-- Основное содержимое -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Название путешествия:" 
                           FontWeight="Bold" Margin="0,5,0,5" Foreground="#555"/>
                <TextBox x:Name="TxtTravelName" Grid.Row="1" Height="35" 
                         Margin="0,0,0,15" Padding="5" FontSize="12"
                         TextChanged="TxtTravelName_TextChanged"/>

                <TextBlock Grid.Row="2" Text="Маршрут (необязательно):" 
                           FontWeight="Bold" Margin="0,5,0,5" Foreground="#555"/>
                <TextBox x:Name="TxtRoute" Grid.Row="3" Height="120" 
                         TextWrapping="Wrap" AcceptsReturn="True"
                         Padding="5" FontSize="12"
                         VerticalScrollBarVisibility="Auto"/>

                <StackPanel Grid.Row="4" Orientation="Horizontal" 
                            HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button x:Name="BtnCreate" Content="✅ Создать" 
                            Width="100" Height="35" Margin="0,0,10,0"
                            Background="#4CAF50" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnCreate_Click" IsEnabled="False"/>
                    <Button x:Name="BtnCancel" Content="❌ Отмена" 
                            Width="100" Height="35"
                            Background="#F44336" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnCancel_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>