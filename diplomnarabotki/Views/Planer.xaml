<Page x:Class="diplomnarabotki.Views.Planer"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:diplomnarabotki"
      xmlns:viewModels="clr-namespace:diplomnarabotki.ViewModels.NoteViewModels"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Планер путешествий"
      Background="#F5F5F5"
      Loaded="Page_Loaded"
      AllowDrop="True">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="10,8"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для ToolTip -->
        <Style TargetType="ToolTip">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="#FFF9C4"
                                BorderBrush="#FF9800"
                                BorderThickness="2"
                                CornerRadius="10"
                                Padding="15"
                                MaxWidth="500">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- Верхняя панель управления -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="White" CornerRadius="5" 
                BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,10" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="BtnNewTravel" Content="➕ Новое путешествие" 
                        Click="BtnNewTravel_Click" Width="160" Height="35" Margin="5"
                        Background="#4CAF50" Foreground="White" BorderThickness="0"
                        Cursor="Hand" FontWeight="Bold"/>

                <Button x:Name="BtnSaveTravel" Content="💾 Сохранить" 
                        Click="BtnSaveTravel_Click" Width="120" Height="35" Margin="5"
                        Background="#2196F3" Foreground="White" BorderThickness="0"
                        Cursor="Hand" FontWeight="Bold"/>

                <Button x:Name="BtnOpenMap" Content="🗺️ Карта маршрута" 
                        Click="BtnOpenMap_Click" Width="140" Height="35" Margin="5"
                        Background="#9C27B0" Foreground="White" BorderThickness="0"
                        Cursor="Hand" FontWeight="Bold"/>

                <Separator Width="20" Visibility="Visible"/>

                <TextBlock Text="Текущее путешествие:" VerticalAlignment="Center" 
                           Margin="10,0,5,0" FontSize="12" Foreground="#666"/>
                <ComboBox x:Name="CmbTravels" Width="200" Height="35" Margin="5"
                          SelectionChanged="CmbTravels_SelectionChanged"
                          FontSize="12" Background="White"/>
            </StackPanel>
        </Border>

        <!-- Левая панель -->
        <Border Grid.Row="1" Grid.Column="0" Background="White" CornerRadius="5" 
                BorderBrush="#E0E0E0" BorderThickness="1" Margin="5" Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="✈️ Информация о путешествии" FontSize="18" 
                               FontWeight="Bold" Margin="0,0,0,15" Foreground="#333"/>

                    <TextBlock Text="Название:" FontWeight="Bold" Margin="0,5,0,0" 
                               FontSize="12" Foreground="#555"/>
                    <TextBox x:Name="TxtTravelName" TextWrapping="Wrap" Height="35" 
                             Margin="0,2,0,10" TextChanged="TravelInfo_Changed" 
                             LostFocus="TxtTravelName_LostFocus"
                             FontSize="12" BorderBrush="#DDD" BorderThickness="1"
                             Padding="5" Background="#FAFAFA"/>

                    <TextBlock Text="🗺️ Маршрут:" FontWeight="Bold" Margin="0,5,0,0" 
                               FontSize="12" Foreground="#555"/>
                    <TextBox x:Name="TxtRoute" TextWrapping="Wrap" Height="80" 
                             Margin="0,2,0,10" TextChanged="TravelInfo_Changed" 
                             LostFocus="TxtRoute_LostFocus"
                             AcceptsReturn="True" FontSize="12" BorderBrush="#DDD" 
                             BorderThickness="1" Padding="5" Background="#FAFAFA"
                             VerticalScrollBarVisibility="Auto"/>

                    <Separator Margin="0,10,0,10" Background="#E0E0E0" Height="1"/>

                    <!-- Закрепленные заметки -->
                    <Border x:Name="PinnedNotesArea" 
                            Background="#FFF9C4" CornerRadius="5" 
                            BorderBrush="#FFD54F" BorderThickness="2" 
                            Margin="0,0,0,0" Padding="10"
                            AllowDrop="True"
                            DragEnter="PinnedNotesArea_DragEnter"
                            DragOver="PinnedNotesArea_DragOver"
                            Drop="PinnedNotesArea_Drop"
                            DragLeave="PinnedNotesArea_DragLeave">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="📌 Закрепленные заметки" FontSize="14" 
                                           FontWeight="Bold" Foreground="#F57C00"/>
                                <TextBlock Text=" (перетащите сюда важные заметки)" 
                                           FontSize="10" Foreground="#F57C00" 
                                           VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </StackPanel>

                            <ScrollViewer MaxHeight="500" VerticalScrollBarVisibility="Auto">
                                <ListBox x:Name="LvPinnedNotes" 
                                         Background="Transparent"
                                         BorderThickness="0"
                                         SelectionMode="Single"
                                         MouseDoubleClick="LvPinnedNotes_MouseDoubleClick">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#FFD54F" BorderThickness="0,0,0,1" 
                                                    Background="#FFF9C4" CornerRadius="5"
                                                    Padding="10" Margin="0,5">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,5">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Icon}" FontSize="16" 
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" 
                                                                   FontSize="14" Foreground="#E65100"
                                                                   TextWrapping="Wrap" Grid.Column="1"
                                                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                        <Button Grid.Column="2" 
                                                                Content="✖" 
                                                                Background="Transparent"
                                                                BorderThickness="0"
                                                                Foreground="#F57C00"
                                                                Cursor="Hand"
                                                                FontSize="12"
                                                                Click="RemovePinnedNote_Click"
                                                                Tag="{Binding Note}"
                                                                ToolTip="Удалить из закрепленных"/>
                                                    </Grid>

                                                    <ContentControl Content="{Binding Note}">
                                                        <ContentControl.Resources>
                                                            <DataTemplate DataType="{x:Type viewModels:TextNoteViewModel}">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Content}" 
                                                                               TextWrapping="Wrap" 
                                                                               FontSize="12" 
                                                                               Foreground="#F57C00"
                                                                               Margin="0,5,0,0"
                                                                               MaxHeight="100"/>
                                                                    <TextBlock Text="📅 Текстовая заметка" 
                                                                               FontSize="9" 
                                                                               Foreground="#FFB74D"
                                                                               Margin="0,5,0,0"/>
                                                                </StackPanel>
                                                            </DataTemplate>

                                                            <DataTemplate DataType="{x:Type viewModels:ListNoteViewModel}">
                                                                <StackPanel Margin="0,5,0,0">
                                                                    <ItemsControl ItemsSource="{Binding Items}" MaxHeight="150">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                                    <TextBlock Text="• " FontSize="12" 
                                                                                               Foreground="#F57C00"/>
                                                                                    <TextBlock Text="{Binding Text}" 
                                                                                               FontSize="12" 
                                                                                               Foreground="#F57C00"
                                                                                               TextWrapping="Wrap"/>
                                                                                </StackPanel>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                    <TextBlock Text="📋 Список" 
                                                                               FontSize="9" 
                                                                               Foreground="#FFB74D"
                                                                               Margin="0,5,0,0"/>
                                                                </StackPanel>
                                                            </DataTemplate>

                                                            <DataTemplate DataType="{x:Type viewModels:ChecklistNoteViewModel}">
                                                                <StackPanel Margin="0,5,0,0">
                                                                    <ItemsControl ItemsSource="{Binding Items}" MaxHeight="150">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                                    <CheckBox IsChecked="{Binding IsChecked}" 
                                                                                              IsEnabled="False"
                                                                                              Margin="0,0,5,0"
                                                                                              VerticalAlignment="Center"/>
                                                                                    <TextBlock Text="{Binding ItemName}" 
                                                                                               FontSize="12" 
                                                                                               Foreground="#F57C00"
                                                                                               TextWrapping="Wrap"/>
                                                                                </StackPanel>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                    <TextBlock Text="✅ Чек-лист" 
                                                                               FontSize="9" 
                                                                               Foreground="#FFB74D"
                                                                               Margin="0,5,0,0"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ContentControl.Resources>
                                                    </ContentControl>

                                                    <TextBlock Text="{Binding CreatedDate, StringFormat=📅 dd.MM.yyyy HH:mm}" 
                                                               FontSize="9" Foreground="#FFB74D" 
                                                               Margin="0,8,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </ScrollViewer>

                            <TextBlock x:Name="TxtEmptyPinned" Text="Перетащите сюда важные заметки из списка справа" 
                                       FontSize="11" Foreground="#F57C00" 
                                       HorizontalAlignment="Center" Margin="0,10,0,0"
                                       Visibility="Visible"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Правая панель - Заметки -->
        <Border Grid.Row="1" Grid.Column="1" Background="White" CornerRadius="5" 
                BorderBrush="#E0E0E0" BorderThickness="1" Margin="5" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="📝 Заметки" FontSize="18" FontWeight="Bold" 
                               Margin="0,0,0,10" Foreground="#333"/>
                </StackPanel>

                <!-- Панель поиска и фильтрации -->
                <StackPanel Grid.Row="1" Margin="0,0,0,15">
                    <TextBox x:Name="TxtSearchNotes" 
                             Margin="0,0,0,10"
                             Style="{StaticResource SearchTextBoxStyle}"
                             TextChanged="TxtSearchNotes_TextChanged"
                             ToolTip="Введите текст для поиска"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="CmbFilterType" Grid.Column="0"
                                  Height="35"
                                  SelectionChanged="CmbFilterType_SelectionChanged"
                                  Background="White"
                                  BorderBrush="#DDD"
                                  FontSize="12">
                            <ComboBoxItem IsSelected="True" Tag="All">📋 Все заметки</ComboBoxItem>
                            <ComboBoxItem Tag="Text">📄 Текстовые</ComboBoxItem>
                            <ComboBoxItem Tag="List">📋 Списки</ComboBoxItem>
                            <ComboBoxItem Tag="Checklist">✅ Чек-листы</ComboBoxItem>
                            <ComboBoxItem Tag="HasNotification">🔔 С уведомлениями</ComboBoxItem>
                        </ComboBox>

                        <Button x:Name="BtnClearSearch" Grid.Column="1"
                                Content="✖ Очистить"
                                Width="90"
                                Height="35"
                                Margin="10,0,0,0"
                                Background="#FF9800"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontWeight="Bold"
                                Click="BtnClearSearch_Click"
                                ToolTip="Очистить поиск и фильтры"/>
                    </Grid>

                    <TextBlock x:Name="TxtSearchResults" 
                               FontSize="11" 
                               Foreground="#666"
                               Margin="0,5,0,0"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"/>

                    <TextBlock Text="💡 Совет: наведите на заметку для просмотра полной информации" 
                               FontSize="10" 
                               Foreground="#999"
                               Margin="0,5,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button x:Name="BtnAddNote" Content="+ Добавить заметку" 
                                Click="BtnAddNote_Click" Width="140" Height="35" 
                                Margin="0,0,10,0" Background="#9C27B0" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
                        <Button x:Name="BtnDeleteNote" Content="✖ Удалить заметку" 
                                Click="BtnDeleteNote_Click" Width="140" Height="35"
                                Background="#F44336" Foreground="White" BorderThickness="0"
                                Cursor="Hand" FontWeight="Bold"/>
                    </StackPanel>

                    <!-- Адаптивная сетка заметок -->
                    <ScrollViewer x:Name="NotesScrollViewer" 
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="IcNotes">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Top"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="NoteBorder"
                                            BorderBrush="#E0E0E0" 
                                            BorderThickness="1" 
                                            Padding="12" 
                                            Margin="8" 
                                            Background="White"
                                            CornerRadius="8"
                                            Width="220"
                                            Height="Auto"
                                            Cursor="Hand"
                                            ToolTipService.ShowDuration="60000"
                                            ToolTipService.InitialShowDelay="500"
                                            ToolTipService.BetweenShowDelay="100">

                                        <!-- Всплывающая подсказка с полным содержанием -->
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled"
                                                              MaxHeight="400">
                                                    <StackPanel>
                                                        <!-- Заголовок -->
                                                        <TextBlock FontWeight="Bold" 
                                                                   FontSize="16" 
                                                                   Foreground="#E65100"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,0,0,12">
                                                            <Run Text="{Binding Icon}"/>
                                                            <Run Text=" "/>
                                                            <Run Text="{Binding Title}"/>
                                                        </TextBlock>

                                                        <!-- Иконка уведомления -->
                                                        <Border Background="#FF9800" CornerRadius="5" 
                                                                Padding="8,4" Margin="0,0,0,10"
                                                                Visibility="{Binding HasNotification, Converter={StaticResource BoolToVisibility}}">
                                                            <TextBlock Text="🔔 Есть уведомление" 
                                                                       FontSize="11" 
                                                                       Foreground="White"
                                                                       FontWeight="Bold"/>
                                                        </Border>

                                                        <!-- Полное содержимое -->
                                                        <ContentControl Content="{Binding Note}">
                                                            <ContentControl.Resources>
                                                                <DataTemplate DataType="{x:Type viewModels:TextNoteViewModel}">
                                                                    <Border Background="White" 
                                                                            CornerRadius="8" 
                                                                            Padding="10"
                                                                            BorderBrush="#E0E0E0"
                                                                            BorderThickness="1"
                                                                            Margin="0,0,0,10">
                                                                        <TextBlock Text="{Binding Content}" 
                                                                                   TextWrapping="Wrap" 
                                                                                   FontSize="13"
                                                                                   Foreground="#333"/>
                                                                    </Border>
                                                                </DataTemplate>

                                                                <DataTemplate DataType="{x:Type viewModels:ListNoteViewModel}">
                                                                    <Border Background="White" 
                                                                            CornerRadius="8" 
                                                                            Padding="10"
                                                                            BorderBrush="#E0E0E0"
                                                                            BorderThickness="1"
                                                                            Margin="0,0,0,10">
                                                                        <ItemsControl ItemsSource="{Binding Items}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <StackPanel Orientation="Horizontal" Margin="0,5">
                                                                                        <TextBlock Text="• " FontSize="14" 
                                                                                                   Foreground="#FF9800"
                                                                                                   Margin="0,0,5,0"/>
                                                                                        <TextBlock Text="{Binding Text}" 
                                                                                                   FontSize="13" 
                                                                                                   TextWrapping="Wrap"
                                                                                                   Foreground="#333"/>
                                                                                    </StackPanel>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </Border>
                                                                </DataTemplate>

                                                                <DataTemplate DataType="{x:Type viewModels:ChecklistNoteViewModel}">
                                                                    <Border Background="White" 
                                                                            CornerRadius="8" 
                                                                            Padding="10"
                                                                            BorderBrush="#E0E0E0"
                                                                            BorderThickness="1"
                                                                            Margin="0,0,0,10">
                                                                        <ItemsControl ItemsSource="{Binding Items}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <StackPanel Orientation="Horizontal" Margin="0,5">
                                                                                        <CheckBox IsChecked="{Binding IsChecked}" 
                                                                                                  IsEnabled="False"
                                                                                                  Margin="0,0,8,0"
                                                                                                  VerticalAlignment="Center"/>
                                                                                        <TextBlock Text="{Binding ItemName}" 
                                                                                                   FontSize="13" 
                                                                                                   TextWrapping="Wrap"
                                                                                                   Foreground="#333"/>
                                                                                        <TextBlock Text=" ✓" 
                                                                                                   FontSize="13" 
                                                                                                   Foreground="#4CAF50"
                                                                                                   Visibility="{Binding IsChecked, Converter={StaticResource BoolToVisibility}}"/>
                                                                                    </StackPanel>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ContentControl.Resources>
                                                        </ContentControl>

                                                        <!-- Дополнительная информация -->
                                                        <Border Background="#FFF0E0" 
                                                                CornerRadius="8" 
                                                                Padding="10"
                                                                Margin="0,5,0,5">
                                                            <StackPanel>
                                                                <TextBlock FontSize="11" Foreground="#666">
                                                                    <Run Text="📅 "/>
                                                                    <Run Text="{Binding CreatedDate, StringFormat=dd.MM.yyyy HH:mm}"/>
                                                                </TextBlock>

                                                                <TextBlock FontSize="11" Foreground="#FF9800"
                                                                           Visibility="{Binding HasNotification, Converter={StaticResource BoolToVisibility}}"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,5,0,0">
                                                                    <Run Text="🔔 "/>
                                                                    <Run Text="{Binding NotificationInfo}"/>
                                                                </TextBlock>

                                                                <TextBlock FontSize="11" Foreground="#4CAF50"
                                                                           Visibility="{Binding HasSearchMatch, Converter={StaticResource BoolToVisibility}}"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,5,0,0">
                                                                    <Run Text="🔍 "/>
                                                                    <Run Text="{Binding SearchHighlight}"/>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Border>

                                                        <TextBlock Text="💡 Дважды кликните для редактирования" 
                                                                   FontSize="10" 
                                                                   Foreground="#999"
                                                                   HorizontalAlignment="Center"
                                                                   FontStyle="Italic"
                                                                   Margin="0,5,0,0"/>
                                                    </StackPanel>
                                                </ScrollViewer>
                                            </ToolTip>
                                        </Border.ToolTip>

                                        <!-- Основное содержимое заметки -->
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Icon}" FontSize="18" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" 
                                                           FontSize="13" Foreground="#333"
                                                           TextWrapping="Wrap" MaxWidth="160"/>
                                                <Border Background="#FF9800" CornerRadius="10" 
                                                        Padding="4,2" Margin="5,0,0,0"
                                                        Visibility="{Binding HasNotification, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="🔔" FontSize="9" Foreground="White"/>
                                                </Border>
                                            </StackPanel>

                                            <TextBlock Text="{Binding PreviewText}" TextWrapping="Wrap" 
                                                       Margin="0,0,0,8" FontSize="11" 
                                                       Foreground="#666" MaxHeight="50"/>

                                            <TextBlock Text="{Binding CreatedDate, StringFormat=📅 dd.MM.yyyy HH:mm}" 
                                                       FontSize="9" Foreground="#999" Margin="0,5,0,0"/>

                                            <TextBlock Text="{Binding NotificationInfo}" 
                                                       FontSize="8" Foreground="#FF9800" 
                                                       Margin="0,5,0,0"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding HasNotification, Converter={StaticResource BoolToVisibility}}"/>

                                            <TextBlock Text="{Binding SearchHighlight}" 
                                                       FontSize="9" Foreground="#4CAF50" 
                                                       Margin="0,5,0,0"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding HasSearchMatch, Converter={StaticResource BoolToVisibility}}"/>

                                            <TextBlock Text="🔍 Наведите для деталей" 
                                                       FontSize="8" 
                                                       Foreground="#FF9800"
                                                       Margin="0,8,0,0"
                                                       HorizontalAlignment="Center"
                                                       FontStyle="Italic"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock x:Name="EmptyNotesText" 
                               Text="😕 Нет заметок. Нажмите '+' чтобы добавить" 
                               FontSize="12" 
                               Foreground="#999"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Диалог создания заметки (остается без изменений) -->
        <Grid x:Name="NoteDialog" Grid.RowSpan="2" Grid.ColumnSpan="2" 
              Background="#80000000" Visibility="Collapsed">
            <Border Background="White" Width="550" Height="650" CornerRadius="10" 
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="#DDD" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="25">
                        <TextBlock Text="📝 Создание заметки" FontSize="18" 
                                   FontWeight="Bold" Margin="0,0,0,20" Foreground="#333"/>

                        <TextBlock Text="Заголовок:" Margin="0,5,0,0" FontWeight="Bold" 
                                   Foreground="#555"/>
                        <TextBox x:Name="TxtNoteTitle" Height="35" Margin="0,2,0,15"
                                 BorderBrush="#DDD" BorderThickness="1" Padding="5"
                                 FontSize="12"/>

                        <TextBlock Text="Тип заметки:" Margin="0,5,0,0" FontWeight="Bold" 
                                   Foreground="#555"/>
                        <ComboBox x:Name="CmbNoteType" Height="35" Margin="0,2,0,15"
                                  SelectionChanged="CmbNoteType_SelectionChanged">
                            <ComboBoxItem Tag="Text" IsSelected="True">📄 Текстовая заметка</ComboBoxItem>
                            <ComboBoxItem Tag="List">📋 Обычный список</ComboBoxItem>
                            <ComboBoxItem Tag="Checklist">✅ Чек-лист</ComboBoxItem>
                        </ComboBox>

                        <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="DynamicContentPanel">
                                <!-- Текстовая заметка -->
                                <StackPanel x:Name="TextNotePanel">
                                    <TextBlock Text="Содержание:" Margin="0,5,0,0" FontWeight="Bold" 
                                               Foreground="#555"/>
                                    <TextBox x:Name="TxtNoteContent" Height="150" TextWrapping="Wrap" 
                                             AcceptsReturn="True" Margin="0,2,0,10"
                                             BorderBrush="#DDD" BorderThickness="1" Padding="5"
                                             FontSize="12" VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>

                                <!-- Список -->
                                <StackPanel x:Name="ListNotePanel" Visibility="Collapsed">
                                    <TextBlock Text="Элементы списка:" Margin="0,5,0,0" FontWeight="Bold" 
                                               Foreground="#555"/>
                                    <ListView x:Name="LvListItems" Height="200" Margin="0,5,0,5"
                                              BorderBrush="#DDD" Background="White">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Элемент" Width="380">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBox Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     BorderThickness="0" Padding="5"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="BtnAddListItem" Content="+ Добавить элемент" 
                                                Click="BtnAddListItem_Click"
                                                Width="120" Height="30" Margin="0,0,5,0"
                                                Background="#4CAF50" Foreground="White" BorderThickness="0"/>
                                        <Button x:Name="BtnRemoveListItem" Content="✖ Удалить элемент" 
                                                Click="BtnRemoveListItem_Click"
                                                Width="120" Height="30" Background="#F44336" 
                                                Foreground="White" BorderThickness="0"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Чек-лист -->
                                <StackPanel x:Name="ChecklistNotePanel" Visibility="Collapsed">
                                    <TextBlock Text="Элементы чек-листа:" Margin="0,5,0,0" FontWeight="Bold" 
                                               Foreground="#555"/>
                                    <ListView x:Name="LvChecklistItems" Height="200" Margin="0,5,0,5"
                                              BorderBrush="#DDD" Background="White">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Width="30">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Элемент" Width="350">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBox Text="{Binding ItemName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     BorderThickness="0" Padding="5"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="BtnAddChecklistItem" Content="+ Добавить элемент" 
                                                Click="BtnAddChecklistItemNote_Click"
                                                Width="120" Height="30" Margin="0,0,5,0"
                                                Background="#4CAF50" Foreground="White" BorderThickness="0"/>
                                        <Button x:Name="BtnRemoveChecklistItem" Content="✖ Удалить элемент" 
                                                Click="BtnRemoveChecklistItemNote_Click"
                                                Width="120" Height="30" Background="#F44336" 
                                                Foreground="White" BorderThickness="0"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Настройки уведомлений -->
                        <Expander Header="🔔 Настройки уведомлений" Margin="0,10,0,0" IsExpanded="False">
                            <StackPanel Margin="0,10,0,0">
                                <CheckBox x:Name="ChkEnableNotification" Content="Включить уведомление" 
                                          Margin="0,0,0,10" Checked="ChkEnableNotification_Checked"
                                          Unchecked="ChkEnableNotification_Unchecked"/>

                                <StackPanel x:Name="NotificationPanel" IsEnabled="False">
                                    <TextBlock Text="Дата и время:" Margin="0,5,0,0" FontWeight="Bold" 
                                               Foreground="#555"/>
                                    <DatePicker x:Name="DatePickerReminder" Width="200" 
                                                Margin="0,2,0,5" HorizontalAlignment="Left"
                                                SelectedDate="{x:Static sys:DateTime.Now}"/>
                                    <TextBox x:Name="TimePickerReminder" Width="120" 
                                             Text="12:00" Margin="0,2,0,10" HorizontalAlignment="Left"
                                             ToolTip="Введите время в формате ЧЧ:ММ"/>

                                    <TextBlock Text="Повторение:" Margin="0,5,0,0" FontWeight="Bold" 
                                               Foreground="#555"/>
                                    <ComboBox x:Name="CmbRepeatType" Width="200" Margin="0,2,0,10"
                                              HorizontalAlignment="Left">
                                        <ComboBoxItem Tag="None">Не повторять</ComboBoxItem>
                                        <ComboBoxItem Tag="EveryMinute">Каждую минуту</ComboBoxItem>
                                        <ComboBoxItem Tag="Every5Minutes">Каждые 5 минут</ComboBoxItem>
                                        <ComboBoxItem Tag="Every10Minutes">Каждые 10 минут</ComboBoxItem>
                                        <ComboBoxItem Tag="Every30Minutes">Каждые 30 минут</ComboBoxItem>
                                        <ComboBoxItem Tag="EveryHour">Каждый час</ComboBoxItem>
                                        <ComboBoxItem Tag="EveryDay">Каждый день</ComboBoxItem>
                                        <ComboBoxItem Tag="EveryWeek">Каждую неделю</ComboBoxItem>
                                    </ComboBox>

                                    <TextBlock Text="Звук уведомления:" Margin="0,5,0,0" FontWeight="Bold" 
                                               Foreground="#555"/>
                                    <ComboBox x:Name="CmbSound" Width="200" Margin="0,2,0,10"
                                              HorizontalAlignment="Left">
                                        <ComboBoxItem Tag="Default">Стандартный</ComboBoxItem>
                                        <ComboBoxItem Tag="Bell">Колокольчик</ComboBoxItem>
                                        <ComboBoxItem Tag="Chime">Мелодичный</ComboBoxItem>
                                        <ComboBoxItem Tag="Alert">Тревога</ComboBoxItem>
                                        <ComboBoxItem Tag="Gentle">Мягкий</ComboBoxItem>
                                    </ComboBox>

                                    <Button x:Name="BtnTestSound" Content="🔊 Тест звука" 
                                            Click="BtnTestSound_Click" Width="120" Height="30" 
                                            Margin="0,10,0,0" Background="#2196F3" Foreground="White"
                                            BorderThickness="0" Cursor="Hand"/>
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                            <Button x:Name="BtnSaveNote" Content="💾 Сохранить" 
                                    Click="BtnSaveNote_Click" Width="100" Height="35" 
                                    Margin="0,0,10,0" Background="#4CAF50" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
                            <Button x:Name="BtnCancelNote" Content="❌ Отмена" 
                                    Click="BtnCancelNote_Click" Width="100" Height="35"
                                    Background="#F44336" Foreground="White" BorderThickness="0"
                                    Cursor="Hand" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>